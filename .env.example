# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@host:port/
DATABASE_NAME=your_database_name
COLLECTION_NAME=your_collection_name

# Feature Flags
# Set to 'false' to disable all MongoDB write operations (trending calculation, thumbnail updates)
ENABLE_MONGO_WRITES=true

# Shorts Feed Sorting
# Time bucket size in days - shorts are grouped into intervals, newest first
SHORT_SORT_INTERVAL=2
# Weight for reward influence vs randomness in sort (0-1, higher = more reward influence)
REWARD_WEIGHT=0.7
# Weight for reshare count influence in sort (0-1, taken from the random portion)
RESHARE_WEIGHT=0.15
# Trending score weights: trending_score = views*1 + votes*2 + comments*3 + reward*10 + reshares*5
TRENDING_VIEWS_WEIGHT=1
TRENDING_VOTES_WEIGHT=2
TRENDING_COMMENTS_WEIGHT=3
TRENDING_REWARD_WEIGHT=10
TRENDING_RESHARE_WEIGHT=5
# Max candidate videos to consider before sorting (trendingSorted endpoint)
TRENDING_CANDIDATE_LIMIT=200
# Hive RPC endpoints (comma-separated, tries in order if one fails)
HIVE_RPC_ENDPOINTS=https://techcoderx.com,https://api.deathwing.me,https://api.hive.blog

# API Security
# Generate a strong random key for production use
# This key is required for protected endpoints like /video/thumbnail
API_SECRET_KEY=your_secret_key_here_change_in_production

# JWT Configuration (optional)
AUTH_JWT_SECRET=your_jwt_secret_here

# Upload Secret Token 
# Used to authenticate the PATCH /api/video/:owner/:permlink/reusable endpoint
UPLOAD_SECRET_TOKEN=secret_upload_token_here_change_in_production

# Hidden Authors (comma-separated, excluded from /feeds/new endpoint)
HIDDEN_AUTHORS=threespeak-fixer,eddiespinod,badadib

# ─── RSS Feed Configuration ───────────────────────────────────────────────────
# Base URL used in the RSS feed's <atom:link rel="self"> tag and <link> elements.
# Should match the public domain of the 3Speak frontend.
# Default: https://3speak.tv
RSS_FEED_BASE_URL=https://3speak.tv

# CDN domain for video files served in RSS <enclosure> tags
# Default: https://threespeakvideo.b-cdn.net
VIDEO_CDN_DOMAIN=https://threespeakvideo.b-cdn.net

# Bunny/IPFS CDN for IPFS-hosted video and thumbnail files
# Default: https://4everland.io
BUNNY_IPFS_CDN=https://4everland.io

# Image CDN for thumbnail URLs
# Default: https://images.3speak.tv
IMAGE_CDN_DOMAIN=https://images.3speak.tv

# ─── Premium Subscription Sync (VSC Okinoko Subs → embed-users.premium) ──────
# Reads the Okinoko Hasura indexer and reflects active subscriptions /
# 1-day passes onto embed-users.premium. Only touches rows tagged
# premium_source='subs' on demote so manual flags stay sticky.
# All values have safe defaults; override only to point at testnet or a
# different contract.
OKI_HASURA_URL=https://api.okinoko.io/hasura/v1/graphql
PREMIUM_SUB_OFFER_IDS=5
PREMIUM_ONETIME_OFFER_IDS=4
PREMIUM_ONETIME_VALIDITY_HOURS=24
PREMIUM_USERS_COLLECTION=embed-users

# ─── collect_subscriptions cron (provider-side billing trigger) ──────────────
# Hourly call to the Okinoko Subs contract that charges due subscribers
# from their prepaid balance. Only runs when BOTH the username and the
# posting key are set — leave either blank to disable the worker
# entirely. Posting key is sufficient (custom_json with no transfer.allow
# intent); use posting, not active.
THREESPEAK_PRO_USERNAME=
THREESPEAK_PRO_POSTING_KEY=
# VSC network + contract — same address used on testnet and mainnet.
VSC_NET_ID=vsc-mainnet
VSC_SUBS_CONTRACT_ID=vsc1BpkPNtC1pBLhxtNn4uE3QkLhudoyzAiXUi
# Comma-separated list of offer IDs to collect each tick. Default 5
# (the recurring sub offer); the 1-day pass at id 4 is one-time and has
# nothing to collect.
COLLECT_SUBS_OFFER_IDS=5
COLLECT_SUBS_INTERVAL_HOURS=1
COLLECT_SUBS_RC_LIMIT=50000
# Audio pay-per-listen heartbeat obfuscation (must match frontend
# VITE_LISTEN_BEAT_KEY). Empty = plaintext beats.
LISTEN_BEAT_KEY=

# Pay-per-listen beneficiary (must match frontend VITE_PPL_BENEFICIARY)
PPL_BENEFICIARY=threespeak-audio

# ─── Pay-per-listen payout worker ───
# Active key of PPL_BENEFICIARY. Empty = dry run (nothing broadcast).
PPL_PAYOUT_ACTIVE_KEY=
PPL_PAYOUT_DRY_RUN=false
# Author portion of each listen (0..1); listener gets the rest. Default 1 (100% to artists).
PPL_AUTHOR_SHARE=1
PPL_PAYOUT_CHECK_HOURS=12
PPL_PAYOUT_MIN=0.001
# Optional one-off payout-moment override (ISO datetime). Empty = weekly Sun 00:00 UTC.
PPL_PAYOUT_PERIOD_END=

# ─── Listen-log consolidation worker ───
# After this many months, audio-listen-log rows are folded into the track's
# embed-audio doc (archivedListens / archivedPayableListens) and deleted, so the
# collection stays bounded. Unpaid payable rows are retained (money-safe).
LISTEN_CONSOLIDATE_MONTHS=5
LISTEN_CONSOLIDATE_CHECK_HOURS=24
LISTEN_CONSOLIDATE_BATCH=1000
# true = log the plan without deleting anything.
LISTEN_CONSOLIDATE_DRY_RUN=false

# Social-link verifier (merged from mantequilla-social-verifier)
SOCIAL_LINKS_COLLECTION=social_links
YOUTUBE_API_KEY=
HIVE_AUTH_REQUIRED=true
SIGNATURE_TIMESTAMP_TOLERANCE_MS=300000
MAX_LINKS_PER_USER=25
UNVERIFIED_TTL_DAYS=3
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
