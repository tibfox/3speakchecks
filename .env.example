# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@host:port/
DATABASE_NAME=your_database_name
COLLECTION_NAME=your_collection_name

# Feature Flags
# Set to 'false' to disable all MongoDB write operations (trending calculation, thumbnail updates)
ENABLE_MONGO_WRITES=true

# Shorts Feed Sorting
# Time bucket size in days - shorts are grouped into intervals, newest first
SHORT_SORT_INTERVAL=2
# Weight for reward influence vs randomness in sort (0-1, higher = more reward influence)
REWARD_WEIGHT=0.7
# Weight for reshare count influence in sort (0-1, taken from the random portion)
RESHARE_WEIGHT=0.15
# Trending score weights: trending_score = views*1 + votes*2 + comments*3 + reward*10 + reshares*5
TRENDING_VIEWS_WEIGHT=1
TRENDING_VOTES_WEIGHT=2
TRENDING_COMMENTS_WEIGHT=3
TRENDING_REWARD_WEIGHT=10
TRENDING_RESHARE_WEIGHT=5
# Max candidate videos to consider before sorting (trendingSorted endpoint)
TRENDING_CANDIDATE_LIMIT=200
# Hive RPC endpoints (comma-separated, tries in order if one fails)
HIVE_RPC_ENDPOINTS=https://techcoderx.com,https://api.deathwing.me,https://api.hive.blog

# API Security
# Generate a strong random key for production use
# This key is required for protected endpoints like /video/thumbnail
API_SECRET_KEY=your_secret_key_here_change_in_production

# JWT Configuration (optional)
AUTH_JWT_SECRET=your_jwt_secret_here

# Upload Secret Token 
# Used to authenticate the PATCH /api/video/:owner/:permlink/reusable endpoint
UPLOAD_SECRET_TOKEN=secret_upload_token_here_change_in_production

# Hidden Authors (comma-separated, excluded from /feeds/new endpoint)
HIDDEN_AUTHORS=threespeak-fixer,eddiespinod,badadib

# ─── RSS Feed Configuration ───────────────────────────────────────────────────
# Base URL used in the RSS feed's <atom:link rel="self"> tag and <link> elements.
# Should match the public domain of the 3Speak frontend.
# Default: https://3speak.tv
RSS_FEED_BASE_URL=https://3speak.tv

# CDN domain for video files served in RSS <enclosure> tags
# Default: https://threespeakvideo.b-cdn.net
VIDEO_CDN_DOMAIN=https://threespeakvideo.b-cdn.net

# Bunny/IPFS CDN for IPFS-hosted video and thumbnail files
# Default: https://4everland.io
BUNNY_IPFS_CDN=https://4everland.io

# Image CDN for thumbnail URLs
# Default: https://images.3speak.tv
IMAGE_CDN_DOMAIN=https://images.3speak.tv