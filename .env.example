# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@host:port/
DATABASE_NAME=your_database_name
COLLECTION_NAME=your_collection_name

# Feature Flags
# Set to 'false' to disable all MongoDB write operations (trending calculation, thumbnail updates)
ENABLE_MONGO_WRITES=true

# Shorts Feed Sorting
# Time bucket size in days - shorts are grouped into intervals, newest first
SHORT_SORT_INTERVAL=2
# Weight for reward influence vs randomness in sort (0-1, higher = more reward influence)
REWARD_WEIGHT=0.7
# Hive RPC endpoints (comma-separated, tries in order if one fails)
HIVE_RPC_ENDPOINTS=https://techcoderx.com,https://api.deathwing.me,https://api.hive.blog

# API Security
# Generate a strong random key for production use
# This key is required for protected endpoints like /video/thumbnail
API_SECRET_KEY=your_secret_key_here_change_in_production

# JWT Configuration (optional)
AUTH_JWT_SECRET=your_jwt_secret_here